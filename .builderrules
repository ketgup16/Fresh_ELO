// âś… Use ButtonGroup
<ButtonGroup>
  <Button variant="secondary">Cancel</Button>
  <Button variant="primary">Save</Button>
</ButtonGroup>

// âś… Use design tokens
<div style={{ backgroundColor: 'var(--ld-semantic-color-fill-primary)' }}>Content</div>
```

